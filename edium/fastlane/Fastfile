require "base64"
require "tmpdir"

default_platform(:ios)

platform :ios do
  desc "Собрать и загрузить в TestFlight"
  lane :beta do
    # Записать API-ключ App Store Connect во временный файл
    api_key_path = File.join(Dir.tmpdir, "asc_api_key.p8")
    File.write(api_key_path, Base64.decode64(ENV.fetch("APP_STORE_CONNECT_API_KEY_BASE64")))

    api_key = app_store_connect_api_key(
      key_id:       ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
      issuer_id:    ENV.fetch("APP_STORE_CONNECT_API_ISSUER_ID"),
      key_filepath: api_key_path,
    )

    # Собрать подписанный IPA (flutter build ios уже выполнен в workflow)
    build_app(
      workspace:             "ios/Runner.xcworkspace",
      scheme:                "Runner",
      configuration:         "Release",
      export_method:         "app-store",
      codesigning_identity:  "Apple Distribution",
      xcargs:                "CODE_SIGN_STYLE=Manual",
      export_options: {
        signingStyle:         "manual",
        provisioningProfiles: {
          "online.edium.app" => ENV.fetch("PROVISIONING_PROFILE_NAME"),
        },
      },
      output_directory:      "build/ios/ipa",
      output_name:           "Edium.ipa",
      suppress_xcode_output: true,
    )

    # Загрузить в TestFlight
    upload_to_testflight(
      api_key:                          api_key,
      skip_waiting_for_build_processing: true,
    )
  ensure
    File.delete(api_key_path) if File.exist?(api_key_path)
  end
end


platform :android do
  desc "Загрузить в RuStore"
  lane :beta do
    apk_path = File.join(
      Dir.pwd, "..", "build", "app", "outputs",
      "flutter-apk", "app-release.apk"
    )
    UI.user_error!("APK не найден: #{apk_path}") unless File.exist?(apk_path)

    rustore_publish(
      key_id:       ENV.fetch("RUSTORE_KEY_ID"),
      private_key:  ENV.fetch("RUSTORE_PRIVATE_KEY_BASE64"),
      package_name:  "online.edium.app",
      gms_apk: apk_path
      publish_type:  "MANUAL",
    )

    UI.success("✅ Загружено в RuStore")
  end
end